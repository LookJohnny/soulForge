# ═══════════════════════════════════════════════
# SoulForge 环境变量配置模板
# 复制为 .env 并填入实际值
# ═══════════════════════════════════════════════

# ─── 环境标识 ───────────────────────────────
# development | production
ENVIRONMENT=development

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://soulforge:soulforge_dev@localhost:5432/soulforge

# ─── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Milvus (向量数据库，RAG 用) ────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ─── MinIO (对象存储) ──────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ─── DashScope (阿里云 AI) ─────────────────
# 获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ─── LLM 大模型 ────────────────────────────
# 可选: dashscope, deepseek, moonshot, glm, openai, ollama
LLM_PROVIDER=dashscope
LLM_MODEL=qwen2.5-7b-instruct
LLM_TIMEOUT=30
# LLM_BASE_URL=          # 自定义 API 地址（可选）
# LLM_API_KEY=           # 自定义 Key（可选，默认用 DASHSCOPE_API_KEY）

# ─── TTS 语音合成 ──────────────────────────
# 可选: dashscope, edge
TTS_PROVIDER=dashscope
TTS_TIMEOUT=15

# ─── ASR 语音识别 ──────────────────────────
ASR_PROVIDER=dashscope
ASR_TIMEOUT=10

# ─── AI Core 服务地址 ──────────────────────
AI_CORE_URL=http://localhost:8100

# ─── 认证 & 安全 ──────────────────────────
# NextAuth 密钥 (admin-web 和 ai-core 共享)
# 生成: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
AUTH_SECRET=change-me
AUTH_TRUST_HOST=true

# Gateway → ai-core 内部服务令牌
# 生成: openssl rand -base64 32
SERVICE_TOKEN=change-me

# SoulPack 加密主密钥
# ⚠️ 生产环境必须修改，禁止默认值
# 生成: openssl rand -base64 32
MASTER_SECRET=change-me-in-production

# ─── CORS 跨域白名单 ───────────────────────
# 逗号分隔；开发环境留空默认允许 localhost
# 生产环境必须配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── 限流 ──────────────────────────────────
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_TTS=20/minute
RATE_LIMIT_DEFAULT=60/minute

# ─── Gateway ───────────────────────────────
GATEWAY_PORT=8080
