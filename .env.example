# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://soulforge:soulforge_dev@localhost:5432/soulforge

# ─── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Milvus ─────────────────────────────────
