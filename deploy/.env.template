# ─── SoulForge Production Environment ───────────
# Copy this file to .env and fill in the values

# ─── Database ─────────────────────────────────
DB_PASSWORD=          # Auto-generated by deploy.sh if empty

# ─── Redis ────────────────────────────────────
REDIS_PASSWORD=       # Auto-generated by deploy.sh if empty

# ─── Auth ─────────────────────────────────────
NEXTAUTH_URL=http://localhost    # Your domain, e.g., https://soulforge.example.com
NEXTAUTH_SECRET=                 # Auto-generated by deploy.sh if empty

# ─── AI Providers ────────────────────────────
DASHSCOPE_API_KEY=               # Required: Alibaba DashScope API key
LLM_PROVIDER=dashscope           # dashscope | deepseek | moonshot | glm | openai | ollama
LLM_MODEL=qwen2.5-7b-instruct   # Model name for the chosen provider
LLM_BASE_URL=                    # Override base URL (optional)
LLM_API_KEY=                     # Override API key (optional, falls back to DASHSCOPE_API_KEY)
TTS_PROVIDER=dashscope           # dashscope | edge
ASR_PROVIDER=dashscope           # dashscope

# ─── Encryption ──────────────────────────────
MASTER_SECRET=                   # Auto-generated by deploy.sh if empty

# ─── MinIO ───────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=                # Auto-generated by deploy.sh if empty

# ─── Server ──────────────────────────────────
PORT=80
